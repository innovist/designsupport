# Environment Configuration
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Core AI API keys
# -----------------------------------------------------------------------------
GEMINI_API_KEYS=your_gemini_api_key_here
IMAGE_GEN_PROVIDER=nano_banana
IMAGE_GENERATION_MODEL=gemini-2.5-flash-image

DEEPSEEK_API_KEY=your_deepseek_api_key_here

YOUTUBE_API_KEYS=your_youtube_api_key_here

BYTEDANCE_SEEDREAM_API_KEY=your_bytedance_seedream_api_key_here

OPENAI_API_KEY=your_openai_api_key_here

ALIBABA_API_KEY=your_alibaba_api_key_here

XIAOMI_MIMO_API_KEY=your_xiaomi_mimo_api_key_here
XIAOMI_MIMO_BASE_URL=https://api.xiaomimimo.com/v1

MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1

KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1

# -----------------------------------------------------------------------------
# Provider endpoint overrides
# -----------------------------------------------------------------------------
ALIBABA_COMPATIBLE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
ALIBABA_TEXT_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/text-generation/generation
ALIBABA_MULTIMODAL_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation

# -----------------------------------------------------------------------------
# Patent / research data
# -----------------------------------------------------------------------------
KIPRIS_SERVICE_KEY=your_kipris_service_key_here
KIPRIS_API_KEY=your_kipris_api_key_here

# -----------------------------------------------------------------------------
# Image provider API keys
# -----------------------------------------------------------------------------
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here
UNSPLASH_ApplicationID=your_unsplash_app_id
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
UNSPLASH_SECRET_KEY=your_unsplash_secret_key

# -----------------------------------------------------------------------------
# Web Search Crawler API
# -----------------------------------------------------------------------------
WEB_SEARCH_CRAWLER_API_BASE_URL=http://localhost:9123
WEB_SEARCH_CRAWLER_API_TOKEN=your_crawler_api_token_here
WEB_SEARCH_CRAWLER_API_POLL_INTERVAL_SECONDS=30

# -----------------------------------------------------------------------------
# Django settings
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=your_django_secret_key_here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://user:password@localhost:5432/designsupport

# -----------------------------------------------------------------------------
# Celery / Redis
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# Object Storage (MinIO/S3)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_STORAGE_BUCKET_NAME=designsupport-media
AWS_S3_ENDPOINT_URL=http://localhost:9000
